# -----------------------------------------------------
# voice-agent - Environment Variables
# Copy this file to voice_agent_backend/.env and fill in the values.
# Never commit voice_agent_backend/.env.
# -----------------------------------------------------

# Application
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ENABLE_RATE_LIMIT=true

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
MAX_FILE_SIZE=52428800

# Providers
GROQ_BASE=https://api.groq.com/openai/v1
GROQ_API_KEY=
OLLAMA_BASE=http://localhost:11434
QDRANT_BASE=http://localhost:6333

# Models
CHAT_PROVIDER=groq
CHAT_MODEL=llama-3.1-8b-instant
TRANSLATION_PROVIDER=groq
TRANSLATION_MODEL=llama-3.1-8b-instant
EMBED_MODEL=mxbai-embed-large:latest
CORRELATOR_PROVIDER=groq
CORRELATOR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# RAG
DEFAULT_COLLECTION=agent_knowledge
RETRIEVAL_TOP_K=12
SUMMARY_TOP_K=16
RERANK_TOP_N=6
SCORE_THRESHOLD=0.25
RETRIEVAL_CONFIDENCE_FLOOR=0.40
SUMMARY_CONFIDENCE_FLOOR=0.35
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
MEMORY_PAIRS=10
CONTEXT_WINDOW_TURNS=3
PREDICTIVE_RAG_TIMEOUT_MS=500

# Voice and TTS
KOKORO_MODE=native
KOKORO_DOCKER_URL=http://127.0.0.1:8880
KOKORO_MODEL_PATH=data/models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=data/models/voices-v1.0.bin
KOKORO_LANG_CODE=a
TTS_HARDWARE=gpu
TTS_SAMPLE_RATE=24000
BACKCHANNEL_PHRASES=["mm-hmm","yeah","I see","got it","right"]
BACKCHANNEL_COOLDOWN_SECONDS=6.0

# Search
ENABLE_SEARCH=true
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=

# Hardware tuning
IO_THREAD_POOL_SIZE=12
GPU_BATCH_SIZE=4
ONNX_INTRA_OP_THREADS=4
ONNX_INTER_OP_THREADS=2
MODELS_TO_CUDA=["kokoro","embed"]
STT_LOCAL_DEVICE=cpu
